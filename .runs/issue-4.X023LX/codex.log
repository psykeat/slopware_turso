    .sort(
      (left, right) => left.displayOrder - right.displayOrder || left.id.localeCompare(right.id),
    );
  const targetSiblingIndex = siblings.findIndex((node) => node.id === targetKey);
  if (targetSiblingIndex === -1) {
    return bucket;
