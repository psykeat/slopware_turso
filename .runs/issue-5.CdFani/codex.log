+function reorderColumnKeys(
+  order: string[],
+  draggedKey: string,
+  targetKey: string,
+  position: "before" | "after",
+) {
+  if (draggedKey === targetKey) return order;
+
+  const next = order.filter((key) => key !== draggedKey);
+  const targetIndex = next.indexOf(targetKey);
+  if (targetIndex < 0) return order;
+
