+  const targetIndex = next.indexOf(targetKey);
+  if (targetIndex < 0) return order;
+
+  const insertAt = position === "before" ? targetIndex : targetIndex + 1;
+  next.splice(insertAt, 0, draggedKey);
+  return next;
+}
