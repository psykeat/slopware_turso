};

const GOOGLE_AUTH_URL = "https://accounts.google.com/o/oauth2/v2/auth";
const MICROSOFT_AUTH_URL = "https://login.microsoftonline.com/common/oauth2/v2.0/authorize";

const GMAIL_SCOPES = [
  "openid",
