+function formatAddressContact(contact: AddressContactSuggestion) {
+  const name = [contact.firstName, contact.lastName].filter(Boolean).join(" ").trim();
+  if (name && contact.email) return `${name} <${contact.email}>`;
+  if (name) return name;
+  return contact.email || "";
+}
