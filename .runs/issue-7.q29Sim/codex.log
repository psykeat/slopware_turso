              addressId: addr.addressId,
              displayLabel: `${addr.companyName || [contact.firstName, contact.lastName].filter(Boolean).join(" ") || addr.addressNo} (${addr.city})`,
              matchScore: 1.0,
              reasons: [`Direkter Treffer über Kontakt-E-Mail: ${email}`],
            });
          }
        }
      }

