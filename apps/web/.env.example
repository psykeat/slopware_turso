VITE_BASE_URL=http://localhost:3000

# Optional hosted Turso/libSQL URLs. When unset, local dev uses `.local-data/`.
TURSO_CONFIG_DATABASE_URL=
TURSO_CONFIG_AUTH_TOKEN=
# Local file config DBs auto-migrate by default. Migrate hosted config DBs with `pnpm --filter @repo/db migrate:config`.
TURSO_CONFIG_AUTO_MIGRATE=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# vp run auth:secret
BETTER_AUTH_SECRET=

# OAuth2 providers, optional, update as needed
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email OAuth2 providers, optional. GOOGLE_* can be reused for Gmail.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Mail credential encryption and OAuth state signing.
# EMAIL_ENCRYPTION_SECRET must be 32 bytes as 64 hex chars. Falls back to ENCRYPTION_SECRET.
EMAIL_ENCRYPTION_SECRET=
# ENCRYPTION_SECRET must be 32 bytes as 64 hex chars. Used for encrypting LiteLLM configuration,
# sales-channel credentials, and other secrets at rest.
ENCRYPTION_SECRET=
EMAIL_OAUTH_STATE_SECRET=
EMAIL_WEBHOOK_TOKEN=
GMAIL_WEBHOOK_TOKEN=
MICROSOFT_WEBHOOK_CLIENT_STATE=

# Shopware / sales-channel credentials are NOT configured here. They live per
# sales channel in the `sales_channel` DB table and are managed via the
# Sales-Channel UI (/app/settings/sales-channels).

# NOTE:
# In your OAuth2 apps, set callback/redirect URIs to`http://localhost:3000/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/github
# Email callback URIs:
# http://localhost:3000/api/email/accounts/callback/google
# http://localhost:3000/api/email/accounts/callback/microsoft

# Dedicated capability test user for HTTP smoke tests (AI_TESTING.md).
# Create once via POST /api/auth/sign-up/email; the user gets its own isolated tenant.
CAPABILITY_TEST_EMAIL=
CAPABILITY_TEST_PASSWORD=
