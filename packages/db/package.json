{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./capabilities": "./src/capabilities/index.ts",
    "./services/*": "./src/services/*.ts"
  },
  "scripts": {
    "db": "drizzle-kit",
    "generate": "drizzle-kit generate && pnpm run docs",
    "migrate": "drizzle-kit migrate && pnpm run docs && pnpm run seed:metadata && pnpm run sync:capabilities",
    "sync:capabilities": "tsx src/scripts/sync-capabilities.ts",
    "docs": "tsx src/scripts/generate-docs.ts",
    "sql": "tsx src/scripts/sql.ts",
    "psql": "tsx src/scripts/psql.ts",
    "seed": "tsx src/scripts/seed.ts",
    "backfill:default-variants": "tsx src/scripts/backfill-default-variants.ts",
    "seed:metadata": "tsx src/scripts/seed-metadata.ts",
    "import-postal-codes": "tsx src/scripts/import-austrian-postal-codes.ts",
    "import-german-postal-codes": "tsx src/scripts/import-german-postal-codes.ts",
    "import-countries": "tsx src/scripts/import-countries.ts",
    "import-countries-csv": "tsx src/scripts/import-countries-csv.ts",
    "seed-currencies": "tsx src/scripts/seed-currencies.ts",
    "seed-skr03": "tsx src/scripts/seed-skr03.ts",
    "seed-austrian-taxes": "tsx src/scripts/seed-austrian-taxes.ts",
    "seed-document-sequences": "tsx src/scripts/seed-document-sequences.ts",
    "setup:reference": "pnpm run import-countries-csv && pnpm run seed-currencies && pnpm run import-postal-codes && pnpm run import-german-postal-codes",
    "test:introspection": "tsx src/scripts/test-introspection.ts",
    "mail:smoke": "tsx src/scripts/mail-smoke.ts",
    "mail:resilience": "tsx src/scripts/mail-resilience-smoke.ts",
    "mail:fixtures": "tsx src/scripts/mail-fixture-tests.ts",
    "auth:generate": "vpx https://pkg.pr.new/auth@9489 generate --config ../auth/src/auth.ts --y --output ./src/schema/auth.schema.ts"
  },
  "dependencies": {
    "@repo/agent": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": "catalog:"
  }
}
