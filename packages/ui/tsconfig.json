{
  "extends": "@repo/tsconfig/base.json",
  "compilerOptions": {
    "types": ["node"],
    "paths": {
      "@repo/registry": ["../registry/src/index.ts"],
      "@repo/registry/*": ["../registry/src/*"],
      "@repo/ui/*": ["./*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
